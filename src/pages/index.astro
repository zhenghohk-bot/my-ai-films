---
import worksData from '../data/works.json';
import '../styles/global.css';

const works = worksData.works.filter(w => w.published);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI FILMS — AI 视频作品集</title>
  <meta name="description" content="全 AI 生成的短片与广告作品集" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="logo">
      <span class="logo-dot"></span>
      AI FILMS
    </a>
    <div class="nav-right">
      <a href="#works" class="nav-link">作品</a>
      <a href="#about" class="nav-link">关于</a>
      <a href="#contact" class="nav-link">联系</a>
      <span class="nav-badge">{works.length} WORKS</span>
    </div>
  </div>
</nav>

<!-- HERO -->
<div class="page">
  <section class="hero" id="about">
    <p class="hero-label">AI FILM PORTFOLIO</p>
    <h1 class="hero-title">
      用 AI 重构<br />
      影像叙事
    </h1>
    <p class="hero-sub">用人工智能探索影像的边界——从奇幻悬疑到商业广告，每一帧都由 AI 生成。</p>
    <p class="hero-sub">鲁迅美术学院数字传媒 谢志康<br />同济大学交互设计 何佩珍</p>
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num">{works.length}</span>
        <span class="stat-label">部作品</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">2025—26</span>
        <span class="stat-label">年代</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">全 AI</span>
        <span class="stat-label">生成</span>
      </div>
    </div>
  </section>
</div>

<!-- WORKS — full bleed -->
<section class="timeline" id="works">
  <div class="page">
    <p class="section-label">WORKS</p>
  </div>
  <div class="timeline-outer">
    <!-- prev arrow -->
    <button class="arrow-btn arrow-prev hidden" id="arrow-prev" aria-label="上一个">‹</button>

    <div class="timeline-track" id="timeline-track">
      <div class="timeline-cards">
        {works.map((work) => {
          const orientation = (work as any).orientation ?? 'landscape';
          return (
            <div class="timeline-slide" data-slide={work.id}>
              <div class="slide-header">
                <span class="slide-dot" data-dot={work.id}></span>
                <span class="slide-date">{work.year}.{work.month}</span>
              </div>
              <div class="work-card" data-card={work.id} data-orientation={orientation}>
                <div class="card-text">
                  <span class="card-id">#{work.id}</span>
                  <span class="type-badge">{work.type}</span>
                  <h2 class="card-title">{work.title}</h2>
                  <p class="card-desc">{work.description}</p>
                  <div class="card-tags">
                    {work.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                </div>
                {work.videoUrl ? (
                  <div class={`card-video--${orientation}`}>
                    <video muted loop playsinline controls preload="none" poster={work.thumbnail}>
                      <source src={work.videoUrl} type="video/mp4" />
                    </video>
                  </div>
                ) : work.thumbnail ? (
                  <div class={`card-video--${orientation}`}>
                    <img src={work.thumbnail} alt={work.title} onerror="this.style.display='none'" />
                  </div>
                ) : (
                  <div class="video-placeholder">VIDEO COMING SOON</div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- next arrow -->
    <button class="arrow-btn arrow-next" id="arrow-next" aria-label="下一个">›</button>
  </div>

  <!-- progress dots -->
  <div class="progress-dots" id="progress-dots">
    {works.map((work, i) => (
      <span class={`progress-dot${i === 0 ? ' active' : ''}`} data-pdot={work.id}></span>
    ))}
  </div>
</section>

<!-- FOOTER -->
<footer id="contact">
  <div class="footer-inner">
    <span class="footer-copy">© 2025–2026 · All works generated by AI</span>
    <a href="https://github.com/zhenghohk-bot/my-ai-films" class="footer-link" target="_blank" rel="noopener">
      GitHub ↗
    </a>
  </div>
</footer>

<script>
  const track    = document.getElementById('timeline-track') as HTMLElement;
  const slides   = Array.from(document.querySelectorAll<HTMLElement>('.timeline-slide'));
  const btnPrev  = document.getElementById('arrow-prev') as HTMLButtonElement;
  const btnNext  = document.getElementById('arrow-next') as HTMLButtonElement;
  const total    = slides.length;

  let currentIdx = 0;
  let autoplayEnabled = true;
  let autoTimer: ReturnType<typeof setTimeout> | null = null;

  // ── update UI for current index ──
  function updateUI(idx: number) {
    const id = slides[idx].dataset.slide!;

    // dots on timeline
    document.querySelectorAll('[data-dot]').forEach(d => d.classList.remove('active'));
    document.querySelector(`[data-dot="${id}"]`)?.classList.add('active');

    // progress dots
    document.querySelectorAll('[data-pdot]').forEach(d => d.classList.remove('active'));
    document.querySelector(`[data-pdot="${id}"]`)?.classList.add('active');

    // arrows
    btnPrev.classList.toggle('hidden', idx === 0);
    btnNext.classList.toggle('hidden', idx === total - 1);
  }

  // ── scroll to slide ──
  function goTo(idx: number, behavior: ScrollBehavior = 'smooth') {
    if (idx < 0 || idx >= total) return;
    currentIdx = idx;
    const slide = slides[idx];
    const offset = slide.offsetLeft - (track.clientWidth - slide.clientWidth) / 2;
    track.scrollTo({ left: offset, behavior });
    updateUI(idx);
  }

  // ── play video ──
  function playSlide(idx: number) {
    const id = slides[idx]?.dataset.slide;
    if (!id) return;
    // pause all others
    slides.forEach((s, i) => {
      if (i !== idx) {
        s.querySelector<HTMLVideoElement>('video')?.pause();
      }
    });
    const video = slides[idx].querySelector<HTMLVideoElement>('video');
    if (!video) return;
    video.currentTime = 0;
    video.play().catch(() => {});
    video.onended = () => {
      if (!autoplayEnabled) return;
      if (idx < total - 1) {
        autoTimer = setTimeout(() => {
          goTo(idx + 1);
          setTimeout(() => playSlide(idx + 1), 850);
        }, 300);
      }
    };
  }

  // ── arrow clicks ──
  btnPrev.addEventListener('click', () => {
    if (autoTimer) clearTimeout(autoTimer);
    autoplayEnabled = false;
    goTo(currentIdx - 1);
    playSlide(currentIdx - 1 < 0 ? 0 : currentIdx - 1);
  });

  btnNext.addEventListener('click', () => {
    if (autoTimer) clearTimeout(autoTimer);
    autoplayEnabled = false;
    const next = currentIdx + 1 < total ? currentIdx + 1 : currentIdx;
    goTo(next);
    playSlide(next);
  });

  // ── detect manual scroll → play snapped slide ──
  let scrolling = false;
  track.addEventListener('scroll', () => {
    if (!scrolling) {
      scrolling = true;
      autoplayEnabled = false;
      if (autoTimer) clearTimeout(autoTimer);
    }
    clearTimeout((track as any)._scrollEnd);
    (track as any)._scrollEnd = setTimeout(() => {
      scrolling = false;
      const center = track.scrollLeft + track.clientWidth / 2;
      let nearest = 0;
      let minDist = Infinity;
      slides.forEach((s, i) => {
        const dist = Math.abs(s.offsetLeft + s.clientWidth / 2 - center);
        if (dist < minDist) { minDist = dist; nearest = i; }
      });
      if (nearest !== currentIdx) {
        currentIdx = nearest;
        updateUI(nearest);
        playSlide(nearest);
      }
    }, 150);
  }, { passive: true });

  // ── init ──
  requestAnimationFrame(() => {
    goTo(0, 'instant');
    setTimeout(() => playSlide(0), 300);
  });
</script>

</body>
</html>
