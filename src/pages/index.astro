---
import worksData from '../data/works.json';
import '../styles/global.css';

const works = worksData.works.filter(w => w.published);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI FILMS — AI 视频作品集</title>
  <meta name="description" content="全 AI 生成的短片与广告作品集" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="logo">
      <span class="logo-dot"></span>
      AI FILMS
    </a>
    <div class="nav-right">
      <a href="#works" class="nav-link">作品</a>
      <a href="#about" class="nav-link">关于</a>
      <a href="#contact" class="nav-link">联系</a>
      <span class="nav-badge">{works.length} WORKS</span>
    </div>
  </div>
</nav>

<!-- HERO -->
<div class="page">
  <section class="hero" id="about">
    <p class="hero-label">AI FILM PORTFOLIO</p>
    <h1 class="hero-title">
      用 AI 重构<br />
      影像叙事
    </h1>
    <p class="hero-sub">用人工智能探索影像的边界——从奇幻悬疑到商业广告，每一帧都由 AI 生成。</p>
    <p class="hero-sub">鲁迅美术学院数字传媒 谢志康<br />同济大学交互设计 何佩珍</p>
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num">{works.length}</span>
        <span class="stat-label">部作品</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">2025—26</span>
        <span class="stat-label">年代</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">全 AI</span>
        <span class="stat-label">生成</span>
      </div>
    </div>
  </section>

  <!-- HORIZONTAL TIMELINE -->
  <section class="timeline" id="works">
    <p class="section-label">WORKS</p>
    <div class="timeline-track" id="timeline-track">
      <div class="timeline-cards">
        {works.map((work) => {
          const orientation = (work as any).orientation ?? 'landscape';
          return (
            <div class="timeline-slide" data-slide={work.id}>
              <div class="slide-header">
                <span class="slide-dot" data-dot={work.id}></span>
                <span class="slide-date">{work.year}.{work.month}</span>
              </div>
              <div class="work-card" data-card={work.id} data-orientation={orientation}>
                <div class="card-text">
                  <span class="card-id">#{work.id}</span>
                  <span class="type-badge">{work.type}</span>
                  <h2 class="card-title">{work.title}</h2>
                  <p class="card-desc">{work.description}</p>
                  <div class="card-tags">
                    {work.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                </div>
                {work.videoUrl ? (
                  <div class={`card-video--${orientation}`}>
                    <video
                      muted
                      loop
                      playsinline
                      controls
                      preload="none"
                      poster={work.thumbnail}
                    >
                      <source src={work.videoUrl} type="video/mp4" />
                    </video>
                  </div>
                ) : work.thumbnail ? (
                  <div class={`card-video--${orientation}`}>
                    <img src={work.thumbnail} alt={work.title} onerror="this.style.display='none'" />
                  </div>
                ) : null}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</div>

<!-- FOOTER -->
<footer id="contact">
  <div class="footer-inner">
    <span class="footer-copy">© 2025–2026 · All works generated by AI</span>
    <a href="https://github.com/zhenghohk-bot/my-ai-films" class="footer-link" target="_blank" rel="noopener">
      GitHub ↗
    </a>
  </div>
</footer>

<script>
  const track = document.getElementById('timeline-track')!;
  const slides = document.querySelectorAll<HTMLElement>('.timeline-slide');
  let currentId: string | null = null;

  function activate(id: string) {
    if (currentId === id) return;
    if (currentId) deactivate(currentId);
    currentId = id;

    document.querySelector(`[data-dot="${id}"]`)?.classList.add('active');
    const video = document.querySelector<HTMLVideoElement>(`[data-card="${id}"] video`);
    video?.play().catch(() => {});
  }

  function deactivate(id: string) {
    document.querySelector(`[data-dot="${id}"]`)?.classList.remove('active');
    const video = document.querySelector<HTMLVideoElement>(`[data-card="${id}"] video`);
    if (video) video.pause();
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        const id = (entry.target as HTMLElement).dataset.slide!;
        if (entry.intersectionRatio >= 0.6) {
          activate(id);
        } else if (currentId === id) {
          deactivate(id);
        }
      });
    },
    { root: track, threshold: [0, 0.6] }
  );

  slides.forEach(s => observer.observe(s));
</script>

</body>
</html>
