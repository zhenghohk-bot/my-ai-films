---
import worksData from '../data/works.json';
import '../styles/global.css';

const works = worksData.works.filter(w => w.published);

function getEmbedUrl(videoUrl: string): string {
  if (!videoUrl) return '';
  // YouTube
  const ytMatch = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}?enablejsapi=1&autoplay=1&mute=1`;
  // Bilibili
  const bvMatch = videoUrl.match(/bilibili\.com\/video\/(BV[A-Za-z0-9]+)/);
  if (bvMatch) return `https://player.bilibili.com/player.html?bvid=${bvMatch[1]}&autoplay=1&muted=1`;
  return videoUrl;
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI FILMS — AI 视频作品集</title>
  <meta name="description" content="全 AI 生成的短片与广告作品集" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<div class="amber-radial"></div>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="logo">
      <span class="logo-dot"></span>
      AI FILMS
    </a>
    <div class="nav-right">
      <a href="#works" class="nav-link">作品</a>
      <a href="#about" class="nav-link">关于</a>
      <a href="#contact" class="nav-link">联系</a>
      <span class="nav-badge">{works.length} WORKS</span>
    </div>
  </div>
</nav>

<!-- HERO -->
<div class="page">
  <section class="hero" id="about">
    <p class="hero-label">AI FILM PORTFOLIO</p>
    <h1 class="hero-title">
      AI 生成<br />
      <span class="dim">影像叙事</span>
    </h1>
    <p class="hero-sub">用人工智能探索影像的边界——从奇幻悬疑到商业广告，每一帧都由 AI 生成。</p>
    <a href="#works" class="hero-cta">浏览作品</a>
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num">{works.length}</span>
        <span class="stat-label">部作品</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">2025—26</span>
        <span class="stat-label">年代</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">全 AI</span>
        <span class="stat-label">生成</span>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="timeline" id="works">
    <p class="section-label">WORKS</p>
    <div class="timeline-list" id="timeline-list">
      {works.map((work) => {
        const embedUrl = getEmbedUrl(work.videoUrl);
        return (
          <div class="timeline-item" data-id={work.id}>
            <div class="timeline-left">
              <span class="timeline-date">{work.year}.{work.month}</span>
              <span class="timeline-dot" data-dot={work.id}></span>
            </div>
            <div
              class="work-card"
              data-card={work.id}
              data-embed={embedUrl}
              data-has-video={work.videoUrl ? 'true' : 'false'}
            >
              <span class="type-badge">{work.type}</span>
              <div class="card-text">
                <span class="card-id">#{work.id}</span>
                <h2 class="card-title">{work.title}</h2>
                <p class="card-desc">{work.description}</p>
                <div class="card-tags">
                  {work.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <div class="card-video" data-video-wrap={work.id}>
                {work.videoUrl ? (
                  <>
                    <img
                      src={work.thumbnail}
                      alt={work.title}
                      data-thumb={work.id}
                      onerror="this.style.display='none'"
                    />
                    <div class="play-overlay">
                      <div class="play-icon">
                        <svg viewBox="0 0 16 16"><polygon points="4,2 14,8 4,14"/></svg>
                      </div>
                    </div>
                  </>
                ) : (
                  <div class="video-placeholder">VIDEO COMING SOON</div>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>
</div>

<!-- FOOTER -->
<footer id="contact">
  <div class="footer-inner">
    <span class="footer-copy">© 2025–2026 · All works generated by AI</span>
    <!-- TODO: 替换为你的 GitHub 仓库地址 -->
    <a href="https://github.com/YOUR_USERNAME/YOUR_REPO_NAME" class="footer-link" target="_blank" rel="noopener">
      GitHub ↗
    </a>
  </div>
</footer>

<script>
  // ── IntersectionObserver: scroll-triggered autoplay ──
  const cards = document.querySelectorAll<HTMLElement>('.work-card');
  let currentPlaying: string | null = null;

  function activateCard(id: string) {
    if (currentPlaying === id) return;

    // deactivate previous
    if (currentPlaying) {
      deactivateCard(currentPlaying);
    }

    currentPlaying = id;

    const card = document.querySelector<HTMLElement>(`[data-card="${id}"]`);
    const dot = document.querySelector<HTMLElement>(`[data-dot="${id}"]`);
    const wrap = document.querySelector<HTMLElement>(`[data-video-wrap="${id}"]`);
    const thumb = document.querySelector<HTMLImageElement>(`[data-thumb="${id}"]`);
    const embedUrl = card?.dataset.embed;
    const hasVideo = card?.dataset.hasVideo === 'true';

    card?.classList.add('playing');
    dot?.classList.add('active');

    if (hasVideo && embedUrl && wrap) {
      // hide thumbnail, inject iframe
      if (thumb) thumb.style.opacity = '0';
      const existing = wrap.querySelector('iframe');
      if (!existing) {
        const iframe = document.createElement('iframe');
        iframe.src = embedUrl;
        iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        wrap.appendChild(iframe);
      }
    }
  }

  function deactivateCard(id: string) {
    const card = document.querySelector<HTMLElement>(`[data-card="${id}"]`);
    const dot = document.querySelector<HTMLElement>(`[data-dot="${id}"]`);
    const wrap = document.querySelector<HTMLElement>(`[data-video-wrap="${id}"]`);
    const thumb = document.querySelector<HTMLImageElement>(`[data-thumb="${id}"]`);

    card?.classList.remove('playing');
    dot?.classList.remove('active');

    // remove iframe to stop playback
    const iframe = wrap?.querySelector('iframe');
    if (iframe) {
      iframe.remove();
      if (thumb) thumb.style.opacity = '1';
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.intersectionRatio >= 0.65) {
          const id = (entry.target as HTMLElement).dataset.card!;
          activateCard(id);
        }
      });
    },
    { threshold: 0.65 }
  );

  cards.forEach(card => observer.observe(card));

  // click on video area also triggers play
  document.querySelectorAll<HTMLElement>('[data-video-wrap]').forEach(wrap => {
    wrap.addEventListener('click', () => {
      const id = wrap.dataset.videoWrap!;
      activateCard(id);
    });
  });
</script>

</body>
</html>
